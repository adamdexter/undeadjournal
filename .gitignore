# --- undeadjournal ---
# Local working clone of the LiveJournal source (re-cloned at Docker build time).
# Anchored to repo root with a leading slash: a bare "lj/" ALSO matches
# overlay/cgi-bin/LJ/ on case-insensitive filesystems (macOS), which silently
# dropped all 27 harvested LJ/* stubs from git and broke the build on clone.
/lj/
# Your exported journal entries (private; never commit your journal).
import/data/
# Local compose overrides
docker-compose.override.yml
# Database backups
backups/

# Installed artwork copies (install artifacts). The tracked source of the
# authentic art is assets/authentic/ (with its DISCLAIMER.md);
# scripts/fetch-authentic-skin.sh copies it here at install time. Keeping the
# copies ignored means assets/authentic/ stays the single tracked source.
overlay/htdocs/img/deadjournal_*.jpg
overlay/htdocs/img/dj_*.jpg
overlay/htdocs/img/miniskull.gif
overlay/htdocs/img/userinfo.gif
overlay/htdocs/img/tomb-small.png
overlay/htdocs/img/mood/
overlay/htdocs/favicon.ico
overlay/htdocs/djstyle.css
_test_ljhome/
build.log
# Your edited Caddyfile (contains your domain + password hash)
caddy/Caddyfile

# Plugin install artifacts (the tracked sources live under plugins/*/files/;
# running plugins/<name>/install.sh copies them here — keeping the copies
# ignored is what makes plugins optional).
overlay/cgi-bin/LJ/AstralProjection.pm
overlay/cgi-bin/ljlib-local.pl
overlay/htdocs/astralprojection.bml
# macOS/Finder duplicate artifacts of the (uncommittable) artwork
overlay/htdocs/img/* 2.*
overlay/htdocs/* 2.*
