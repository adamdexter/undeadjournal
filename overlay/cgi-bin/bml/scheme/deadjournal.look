<!-- END DEAD JOURNAL FOOTER -->
		</td>
		<td width="20" background="<?imgprefix?>/dj_rightback.jpg" align="right"><img src="<?imgprefix?>/dot.gif" width="20" height="1" alt=""></td>
	</tr>
</table>
<!-- END MAIN NESTOID -->
	</td></tr>
	<tr>
		<td width="245" background="<?imgprefix?>/deadjournal_footer_03.jpg" align="left"><img src="<?imgprefix?>/deadjournal_footer_02.jpg" width="245" height="75" border="0" alt=""></td>
		<td width="30" background="<?imgprefix?>/deadjournal_footer_03.jpg"><img src="<?imgprefix?>/deadjournal_footer_03.jpg" width="30" height="75" alt=""></td>
		<td width="250" background="<?imgprefix?>/deadjournal_footer_03.jpg" align="center"><img src="<?imgprefix?>/deadjournal_footer_04.jpg" width="250" height="75" border="0" usemap="#Map" alt=""></td>
		<td width="30" background="<?imgprefix?>/deadjournal_footer_03.jpg"><img src="<?imgprefix?>/deadjournal_footer_05.jpg" width="30" height="75" alt=""></td>
		<td background="<?imgprefix?>/deadjournal_footer_03.jpg" width="245" align="right"><img src="<?imgprefix?>/deadjournal_footer_06.jpg" width="245" height="75" alt=""></td>
	</tr>
</table>
<map name="Map"><area shape="rect" coords="53,55,200,69" href="http://www.mindvamp.com/" target="_blank" alt="site design: mindvamp"></map>
