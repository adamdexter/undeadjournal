#
# DeadJournal site scheme — faithful to the 2006-04-04 Wayback capture of
# www.deadjournal.com (the classic 2003-2006 chrome). Inherits inner BML blocks
# from global.look; overrides PAGE so every site page gets the authentic frame:
#
#   - centered 800px table on black, exact original BODY colors
#   - header band 245/30/250/30/245 (bone ends, tiling purple bar, skull center)
#   - "MAIN NESTOID" middle: 20px bone gutters | left sidebar nav | content
#   - inner text footer (hr #330066, Login/Logout/OpenID, (c)Dead Journal)
#   - footer band with the mindvamp.com imagemap credit, header logo maps home
#
# Faithful deviations: the two tiling cells use WIDTH=30 images (as the current
# live site does) instead of 2006's overflowing WIDTH=87/70, so the table sums to
# exactly 800px in modern browsers; sidebar entries whose pages don't exist in
# this build (Grim Reaping/Download, Offerings, DJ News, Advertise, Schools,
# Hauntings) are omitted. The logged-in member nav (R.I.P. block, Your Death
# Bed, Login Settings, Coffin Accessories) is reconstructed from a 2026
# screenshot of the live site — no logged-in Wayback capture exists.
#

_parent=>global.look

PAGE<=
{Fp}<html>
<head><title>%%title%%</title>
<?_code LJ::res_includes() _code?>
<link href="/djstyle.css" rel="stylesheet" type="text/css">
<style type="text/css">
  BODY,TABLE,TR,TD { font-family:arial; font-size:12px; }
  /* authentic 2006 login-box touch: tombstone icon inside the username field */
  input[name="user"] { background: #fff url(<?imgprefix?>/tomb-small.png) no-repeat 0px 1px; padding-left: 18px; color: #00C; font-weight: bold; }
</style>
<link rel="shortcut icon" href="/favicon.ico" type="image/x-icon">
<meta name="description" content="DeadJournal.com ... words words.">
<meta name="keywords" content="diary,journal">
%%head%%
</head>
<body bgcolor="#000000" marginheight="0" marginwidth="0" leftmargin="0" topmargin="0" link="#200095" vlink="#160066" alink="#171918" text="#201b2f" %%bodyopts%%><center>
<table border="0" cellpadding="0" cellspacing="0" width="800">
	<tr align="right">
		<td width="245" background="<?imgprefix?>/deadjournal_header_02.jpg" align="left"><img src="<?imgprefix?>/deadjournal_header_01.jpg" width="245" height="155" alt="Dead Journal" border="0"></td>
		<td width="30" background="<?imgprefix?>/deadjournal_header_02.jpg"><img src="<?imgprefix?>/deadjournal_header_02.jpg" width="30" height="155" alt=""></td>
		<td width="250" background="<?imgprefix?>/deadjournal_header_02.jpg" align="center"><img src="<?imgprefix?>/deadjournal_header_03.jpg" alt="Dead Journal" width="250" height="155" border="0" usemap="#Map2"></td>
		<td width="30" background="<?imgprefix?>/deadjournal_header_04.jpg"><img src="<?imgprefix?>/deadjournal_header_04.jpg" width="30" height="155" alt=""></td>
		<td width="245"><img src="<?imgprefix?>/deadjournal_header_05.jpg" width="245" height="155" alt="Dead Journal"></td>
	</tr>
	<tr><td colspan="5" background="<?imgprefix?>/dj_midback.jpg">
<!-- BEGIN MAIN NESTOID -->
<table cellpadding="0" cellspacing="0" border="0" width="800">
	<tr>
		<td width="20" background="<?imgprefix?>/dj_leftback.jpg" align="left"><img src="<?imgprefix?>/dot.gif" width="20" height="1" alt=""></td>
		<td valign="top" class="bodytext" background="<?imgprefix?>/dj_midback.jpg" width="150">
<!-- BEGIN LEFT COL -->
<p><?_code
    # Logged out: Enter the Crypt (faithful to the 2006 logged-out capture).
    # Logged in: the full member nav — no logged-in Wayback capture exists, so
    # this is reconstructed from 2026 screenshots of the live site's sidebar,
    # with each gothic label mapped to this engine's page for that function:
    #   Your Grave=your journal, Login Options=login.bml (shows session state),
    #   Session Manager=manage/logins.bml, Resurrection=logout,
    #   Paper Trails=update.bml, Obituary=userinfo.bml (your profile, read),
    #   Survived by...=your friends page (Filters=friends/filter.bml),
    #   Timeline=calendar view, Eulogy=tools/memories.bml.
    #   (Editing lives under Coffin Accessories, matching the live site.)
    my $icon = qq{<img src="$LJ::IMGPREFIX/userinfo.gif" width="10" height="10" hspace="2" align="absmiddle">};
    my $remote = eval { LJ::get_remote() };
    if ($remote) {
        my $user = LJ::ehtml($remote->{user});
        my $ret = qq{$icon<b>R.I.P.&nbsp;$user!</b><br>} .
                  qq{&nbsp;&nbsp;&nbsp;&nbsp;- <a href="/users/$user/">Your&nbsp;Grave</a><br>} .
                  qq{&nbsp;&nbsp;&nbsp;&nbsp;- <a href="/login.bml">Login&nbsp;Options</a><br>} .
                  qq{&nbsp;&nbsp;&nbsp;&nbsp;- <a href="/manage/logins.bml">Session&nbsp;Manager</a><br>} .
                  qq{&nbsp;&nbsp;&nbsp;&nbsp;- <a href="/logout.bml">Resurrection</a>};
        $ret .= qq{<br>&nbsp;&nbsp;&nbsp;&nbsp;- <a href="/astralprojection.bml">Astral&nbsp;Projection</a>}
            if $LJ::AstralProjection::VERSION;
        $ret .= qq{<p>$icon<b>Your&nbsp;Death&nbsp;Bed</b><br>} .
                qq{&nbsp;&nbsp;&nbsp;&nbsp;- <a href="/update.bml">Paper&nbsp;Trails</a><br>} .
                qq{&nbsp;&nbsp;&nbsp;&nbsp;- <a href="/userinfo.bml?user=$user">Obituary</a><br>} .
                qq{&nbsp;&nbsp;&nbsp;&nbsp;- <a href="/users/$user/friends">Survived&nbsp;by...</a><br>} .
                qq{&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;- <a href="/friends/filter.bml">Filters</a><br>} .
                qq{&nbsp;&nbsp;&nbsp;&nbsp;- <a href="/users/$user/calendar">Timeline</a><br>} .
                qq{&nbsp;&nbsp;&nbsp;&nbsp;- <a href="/tools/memories.bml">Eulogy</a>};
        return $ret;
    }
    return qq{$icon<a href="/login.bml">Enter&nbsp;the&nbsp;Crypt</a><br>} .
           qq{&nbsp;&nbsp;&nbsp;&nbsp;- <a href="/openid/">OpenID</a>};
_code?>
<p><img src="<?imgprefix?>/userinfo.gif" width="10" height="10" hspace="2" align="absmiddle"><b>The&nbsp;Cemetery</b><br>&nbsp;&nbsp;&nbsp;&nbsp;- <?_code
    my $uri = eval { BML::get_uri() } || '';
    return $uri =~ m!^/(index\.bml)?$!
        ? '<b><span style="background-color: #c6bfb7"><font color="#bd0031">The&nbsp;Morgue</font></span></b>'
        : '<a href="/">The&nbsp;Morgue</a>';
_code?><br><?_code
    # Login Settings appears in the live site's Cemetery menu when logged in.
    return eval { LJ::get_remote() }
        ? '&nbsp;&nbsp;&nbsp;&nbsp;- <a href="/manage/settings/">Login&nbsp;Settings</a><br>' .
          '&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;- <a href="/openid/">OpenID</a><br>'
        : '';
_code?>&nbsp;&nbsp;&nbsp;&nbsp;- <a href="/create.bml">Join&nbsp;the&nbsp;Undead</a><br>
<p><img src="<?imgprefix?>/userinfo.gif" width="10" height="10" hspace="2" align="absmiddle"><b>Morgue&nbsp;Directory</b><br>&nbsp;&nbsp;&nbsp;&nbsp;- <a href="/random.bml">Random&nbsp;Grave</a><br>&nbsp;&nbsp;&nbsp;&nbsp;- <a href="/directory.bml">Place&nbsp;of&nbsp;Death</a><br>&nbsp;&nbsp;&nbsp;&nbsp;- <a href="/directorysearch.bml">Search&nbsp;Morgue</a><br>&nbsp;&nbsp;&nbsp;&nbsp;- <a href="/interests.bml">Interests</a><br>
<?_code
    # Coffin Accessories + Design Your Tomb (logged-in only on the live
    # site) — the management menus, full lists from 2026 screenshots of the
    # live site. Gothic label → function: Edit Tombstone=edit profile,
    # Dead Friends=edit friends, Old Entries=edit entries, Autopsy
    # Photos=userpics, Dead Password=change password, Grave
    # Management=journal management, Community Manager / Tag Manager as
    # named; Butcher=S1 styles, Mutilate=S2 customize wizard, Style
    # Create/Edit=S1 style editor, Moody Dead=mood themes.
    my $remote = eval { LJ::get_remote() } or return '';
    my $icon = qq{<img src="$LJ::IMGPREFIX/userinfo.gif" width="10" height="10" hspace="2" align="absmiddle">};
    return qq{<p>$icon<b>Coffin&nbsp;Accessories</b><br>} .
           qq{&nbsp;&nbsp;&nbsp;&nbsp;- <a href="/manage/profile/">Edit&nbsp;Tombstone</a><br>} .
           qq{&nbsp;&nbsp;&nbsp;&nbsp;- <a href="/friends/edit.bml">Dead&nbsp;Friends</a><br>} .
           qq{&nbsp;&nbsp;&nbsp;&nbsp;- <a href="/editjournal.bml">Old&nbsp;Entries</a><br>} .
           qq{&nbsp;&nbsp;&nbsp;&nbsp;- <a href="/editpics.bml">Autopsy&nbsp;Photos</a><br>} .
           qq{&nbsp;&nbsp;&nbsp;&nbsp;- <a href="/changepassword.bml">Dead&nbsp;Password</a><br>} .
           qq{&nbsp;&nbsp;&nbsp;&nbsp;- <a href="/manage/">Grave&nbsp;Management</a><br>} .
           qq{&nbsp;&nbsp;&nbsp;&nbsp;- <a href="/community/manage.bml">Community&nbsp;Manager</a><br>} .
           qq{&nbsp;&nbsp;&nbsp;&nbsp;- <a href="/manage/tags.bml">Tag&nbsp;Manager</a><br>} .
           qq{<p>$icon<b>Design&nbsp;Your&nbsp;Tomb</b><br>} .
           qq{&nbsp;&nbsp;&nbsp;&nbsp;- <a href="/styles/">Butcher&nbsp;(S1)</a><br>} .
           qq{&nbsp;&nbsp;&nbsp;&nbsp;- <a href="/customize/">Mutilate&nbsp;(S2)</a><br>} .
           qq{&nbsp;&nbsp;&nbsp;&nbsp;- <a href="/styles/create.bml">Style&nbsp;Create</a><br>} .
           qq{&nbsp;&nbsp;&nbsp;&nbsp;- <a href="/styles/edit.bml">Style&nbsp;Edit</a><br>} .
           qq{&nbsp;&nbsp;&nbsp;&nbsp;- <a href="/manage/moodthemes.bml">Moody&nbsp;Dead</a><br>};
_code?>
<p><img src="<?imgprefix?>/userinfo.gif" width="10" height="10" hspace="2" align="absmiddle"><b>Botched&nbsp;Murders</b><br>&nbsp;&nbsp;&nbsp;&nbsp;- <a href="/support/faq.bml">FAQ</a><br>&nbsp;&nbsp;&nbsp;&nbsp;- <a href="/lostinfo.bml">Lost&nbsp;Info?</a><br>&nbsp;&nbsp;&nbsp;&nbsp;- <a href="/support/">Spoon&nbsp;Feeding</a><br>
<!-- END LEFT COL -->
		</td>
		<td width="5" valign="top" align="left"><img src="<?imgprefix?>/dot.gif" width="5" height="1" alt=""></td>
		<td valign="top" class="bodytext" background="<?imgprefix?>/dj_midback.jpg" width="500">
<!-- BEGIN RIGHT COL -->
<?_code
    return @errors && scalar @errors ? LJ::error_list(@errors) : '';
_code?>
%%body%%
<!-- END RIGHT COL -->
		</td>
		<td width="20" background="<?imgprefix?>/dj_rightback.jpg" align="right"><img src="<?imgprefix?>/dot.gif" width="20" height="1" alt=""></td>
	</tr>
	<tr>
		<td width="20" background="<?imgprefix?>/dj_leftback.jpg" align="left"><img src="<?imgprefix?>/dot.gif" width="20" height="1" alt=""></td>
		<td colspan="3" align="center" background="<?imgprefix?>/dj_midback.jpg" class="djfooter">
<!-- BEGIN DEAD JOURNAL FOOTER -->
<hr nohade size="1" color="#330066">
<a href="/login.bml">Login/Logout</a><a href="/openid/">/OpenID</a>
