# UnDeadJournal configuration.
#
# EASIEST: don't edit this by hand — run  ./setup.sh  and it writes .env for you.
#
# To configure manually instead: copy this file to ".env" (same folder as
# docker-compose.yml) and edit. The .env file is gitignored — your passwords
# never end up in git.

# --- How the site is reached ---------------------------------------------------
# The address you will type in your browser. For your own computer, keep the
# defaults. For a home server / NAS, use its LAN IP or Tailscale name, e.g.:
#   LJ_DOMAIN=192.168.1.50:8080
#   LJ_SITEROOT=http://192.168.1.50:8080
#   LJ_SERVERNAME=192.168.1.50
LJ_DOMAIN=localhost:8080
LJ_SITEROOT=http://localhost:8080
LJ_SERVERNAME=localhost

# Which port to publish, and where to listen:
#   BIND_ADDR=127.0.0.1 → only this computer can reach it (safest)
#   BIND_ADDR=0.0.0.0   → other devices on your network can reach it
HTTP_PORT=8080
BIND_ADDR=127.0.0.1

# --- Branding & look -------------------------------------------------------------
# Shown in page titles and site text.
SITE_NAME=DeadJournal
# "deadjournal" = the authentic 2003 gothic chrome (requires the artwork —
# run scripts/fetch-authentic-skin.sh, or let setup.sh do it).
# "bluewhite"  = the stock classic-LiveJournal look (no artwork needed).
LJ_SCHEME=deadjournal

# --- Secrets (CHANGE THESE — setup.sh generates random ones) ---------------------
# Password for the built-in 'system' admin account (set on first-run bootstrap).
SYSTEM_PASSWORD=change-me-system-pass
# MariaDB passwords.
DB_PASSWORD=change-me-db-pass
DB_ROOT_PASSWORD=change-me-root-pass
