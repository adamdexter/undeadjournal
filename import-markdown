#!/usr/bin/env bash
# Post a folder of Markdown notes into your LOCAL journal, using each file's
# creation date as the entry date. Interactive — just run it:
#   ./import-markdown --dir "path/to/your/notes"
#   ./import-markdown --dir DIR --dry-run          (preview, post nothing)
#   ./import-markdown --dir DIR --security public  (default is private)
exec python3 "$(dirname "$0")/import/load_markdown.py" "$@"
